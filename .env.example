# Marka aad dhigayso (deploy) Vercel, ku dar environment variable-kan
# Settings ee Vercel project-kaaga: Project → Settings → Environment Variables
#
# Key:   VITE_API_URL
# Value: https://<backend-kaaga-public-domain>/api
#
# Tusaale: https://vehicle-api.onrender.com/api

VITE_API_URL=https://localhost:7204/api
